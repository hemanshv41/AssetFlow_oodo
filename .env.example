# ---- AssetFlow environment variables ----
# On Vercel, set these in Project Settings → Environment Variables.
# For local development, copy this file to `.env` in the repo root (and/or backend/).

# Postgres connection string.
# Local:   postgres://postgres:postgres@localhost:5432/assetflow
# Supabase (production): use the POOLED connection string (port 6543 / pgbouncer),
#   e.g. postgres://USER:PASSWORD@HOST:6543/postgres?sslmode=require
DATABASE_URL=

# Secret used to sign JWTs. Use a long random string in production
# (e.g. `openssl rand -hex 32`). Never commit the real value.
JWT_SECRET=

# Optional: comma-separated list of allowed CORS origins.
# Leave empty for a single-domain deploy (frontend and API share one host).
# CORS_ORIGIN=https://your-app.vercel.app

# Optional (frontend, build-time): only needed if the API is hosted on a
# DIFFERENT domain than the frontend. Leave unset for the single-project deploy.
# VITE_API_URL=https://your-api.example.com
