# Copy this file to .env and paste the team's shared Supabase connection string.
#
# Get it from: Supabase Dashboard → your project → Connect (top bar) →
# "Session pooler" connection string (works on any network, unlike the direct one which is IPv6-only).
# It looks like:
# DATABASE_URL=postgresql://postgres.abcdefghijklm:YOUR-PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres
#
# NOTE: use the Session pooler (port 5432), NOT the Transaction pooler (port 6543).

PORT=5000
DATABASE_URL=
JWT_SECRET=assetflow-hackathon-secret

